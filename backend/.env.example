# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
WEB_URL=http://localhost:3001
MOBILE_DEEPLINK=sportsbooking://

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sports_booking?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TTL=30d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Mail (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Sports Booking <no-reply@sportsbooking.local>"

# SMS (SpeedSMS hoặc Twilio)
SMS_PROVIDER=speedsms
SMS_API_KEY=
SMS_SENDER=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sports-booking
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/sports-booking

# Commission (%) — platform giữ lại từ mỗi booking COMPLETED
PLATFORM_COMMISSION_PERCENT=10

# ====== VNPay ======
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_RETURN_URL=http://localhost:3000/payments/return/vnpay
VNPAY_IPN_URL=http://localhost:3000/payments/webhooks/vnpay

# ====== MoMo ======
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

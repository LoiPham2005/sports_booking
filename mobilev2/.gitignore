# Firebase
firebase_options*.dart

# Firebase config files được commit cùng repo (per-flavor):
#   android/app/src/{dev,stg,prod}/google-services.json
#   ios/Runner/{dev,stg,prod}/GoogleService-Info.plist
# Firebase keys không phải secrets (security qua bundle ID + Firebase rules).
# Nếu cần private/public template → uncomment 2 dòng dưới để skip:
# android/app/src/*/google-services.json
# ios/Runner/*/GoogleService-Info.plist


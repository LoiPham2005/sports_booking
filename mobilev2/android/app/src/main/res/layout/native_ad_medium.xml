<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout cho native ad MEDIUM (~300dp height) — Google Mobile Ads SDK.
  Bind data trong NativeAdFactoryMedium.kt.
  Màu: xem res/values/colors.xml
  Shape: xem res/drawable/ad_*.xml
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ad_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Media (image / video) -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="8dp" />

        <!-- Headline + icon row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ad_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ad_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/ad_advertiser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ad_text_tertiary"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ad_badge_background"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Ad"
                android:textColor="@color/ad_badge_text"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Body -->
        <TextView
            android:id="@+id/ad_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/ad_text_secondary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Call-to-action button -->
        <Button
            android:id="@+id/ad_call_to_action"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/ad_cta_button"
            android:textColor="@color/ad_cta_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

</com.google.android.gms.ads.nativead.NativeAdView>

# Copy this file to .env.dev / .env.stg / .env.prod and fill values.
# These are loaded at COMPILE time by envied. Never commit real values.

API_BASE_URL=https://api.example.com
API_KEY=

# OAuth (if any)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Firebase (optional override)
FIREBASE_WEB_API_KEY=

# Third-party
REVENUE_CAT_API_KEY=
ADMOB_APP_ID=
SENTRY_DSN=

# Sports Booking — Frontend env
# Copy: cp .env.local.example .env.local

# Backend API base (KHÔNG có /api/v1 cuối — client.ts tự thêm)
NEXT_PUBLIC_API_BASE=http://localhost:3000

# Mock data toggle:
# - true: dùng mock từ lib/mock-data.ts (default, an toàn cho dev không có backend)
# - false: gọi API thật. Phải có backend chạy ở NEXT_PUBLIC_API_BASE.
NEXT_PUBLIC_USE_MOCK=true
